# /etc/sysconfig/dr-load-recorder
# ─────────────────────────────────────────────────────────────────────────────
# Environment file for the dr-load-recorder systemd service.
#
# Edit this file before enabling the service.  Variables without a value set
# here will use the daemon's built-in defaults.
#
# Syntax:  KEY=value   (no export keyword; no quoting required for simple values)
# Restart the service after editing:  sudo systemctl restart dr-load-recorder
# ─────────────────────────────────────────────────────────────────────────────

# ── Digital Reef server connection ───────────────────────────────────────────

# DR_HOST: HTTPS base URL of the Digital Reef server.
# Include the port; omit the trailing slash.
# Default (from config.py): https://192.168.58.128:8443
DR_HOST=https://192.168.58.128:8443

# DR_ORG: Organization name to poll metrics for.
# The recorder will enumerate all projects in this org.
# Default: training  (the standard QA org)
DR_ORG=training

# DR_USER: DRSysAdmin (or Org Admin) username for API authentication.
# The recorder uses the same credentials as dr-load preflight.
DR_USER=DRSysAdmin

# DR_PASSWORD: Password for DR_USER.
# IMPORTANT: set file permissions to 0640 root:auraria to protect this value.
#            The default install sets those permissions automatically.
DR_PASSWORD=changeme

# DR_VERIFY_SSL: Set to "false" to skip TLS certificate verification.
# The DR test server uses a self-signed cert; set false for lab environments.
# Never set false in production.
DR_VERIFY_SSL=false

# ── Recorder daemon tuning ────────────────────────────────────────────────────

# DR_STORE: Path to the SQLite TSDB file.
# The recorder writes metrics here; dr-load report reads from here.
# Must be writable by the auraria user.
DR_STORE=/var/lib/dr-load-recorder/store.db

# DR_TICK: Metric sampling interval in seconds.
# Lower values give finer time resolution but increase API load on the DR server.
# Default: 10
DR_TICK=10

# ── Log file ─────────────────────────────────────────────────────────────────
# The systemd unit writes stdout/stderr to /var/log/dr-load-recorder.log.
# Rotate with logrotate; a sample config is provided in packaging/logrotate/.
# No env var needed — this is configured in the unit file directly.
