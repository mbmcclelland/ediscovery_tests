    align: center middle;
}

#reset-card {
    width: 60;
    height: auto;
    padding: 1 2;
    border: round $warning;
    background: $panel;
}

#reset-title {
    content-align: center middle;
    color: $warning;
    text-style: bold;
    margin-bottom: 1;
}

#reset-card Label {
    margin-top: 1;
    color: grey;
}

#reset-error {
    color: $error;
    margin-top: 1;
    height: auto;
}

#reset-buttons {
    height: 3;
    align: center middle;
    margin-top: 1;
}

#reset-buttons Button {
    margin: 0 1;
    min-width: 12;
}

GroupFormModal {
    align: center middle;
}

#group-card {
    width: 70;
    height: auto;
    padding: 1 2;
    border: round $accent;
    background: $panel;
}

#group-title {
    content-align: center middle;
    color: $accent;
    text-style: bold;
    margin-bottom: 1;
}

#group-card Label {
    margin-top: 1;
    color: grey;
}

#group-error {
    color: $error;
    margin-top: 1;
    height: auto;
}

#group-buttons {
    height: 3;
    align: center middle;
    margin-top: 1;
}

#group-buttons Button {
    margin: 0 1;
    min-width: 12;
}
