# eDiscovery API Test Configuration
# Copy this file to .env and fill in your values
#
# All variables use a DR_ prefix to avoid collisions with
# Windows system env vars (e.g. Windows sets USERNAME automatically).

# Base URL for the eDiscovery REST API (no trailing slash)
DR_BASE_URL=https://192.168.58.128:8443/ediscovery/rest

# ============================================================
# System Admin (realm-level access)
# Used by the main test suite (pytest -v)
# ============================================================
DR_USERNAME=DRSysAdmin
DR_PASSWORD=your_password_here
DR_ORGANIZATION=super_system_customer

# ============================================================
# Org User (org-level access, e.g. admin@training)
# Used by org_user tests (pytest -m org_user -v)
# Leave blank to skip org-user tests automatically.
# ============================================================
DR_ORG_USERNAME=admin
DR_ORG_PASSWORD=your_org_password_here
DR_ORG_ORGANIZATION=training

# ============================================================
# Optional settings
# ============================================================
# LDAP domain (leave empty if not using LDAP)
DR_LDAP_DOMAIN=
DR_ORG_LDAP_DOMAIN=

# Timeouts (seconds)
DR_REQUEST_TIMEOUT=30
DR_LONG_REQUEST_TIMEOUT=120

# Load test settings
DR_LOAD_TEST_USERS=10
DR_LOAD_TEST_SPAWN_RATE=2
DR_LOAD_TEST_DURATION=60

# SSL verification (set to false for self-signed certs)
DR_VERIFY_SSL=false

# ============================================================
# Indexing Workflow Settings
# Used by test_indexing_workflow.py and locustfile_indexing.py
# ============================================================
# NFS connector handle (from orgManager/listConnectors)
DR_NFS_CONNECTOR_HANDLE=0000840201143a35f1f34d8d9a76a34146268ddc
DR_NFS_IMPORT_PATH=/test_datasets/Small Sample
DR_NFS_DATASET_NAME=Small Sample

# Admin role handle for project membership
DR_ADMIN_ROLE_HANDLE=00008798cf6b043a18104ccd8c437b29f688f847

# Template attribute IDs are now auto-discovered at runtime via
# orgManager/listTemplates (see EDiscoveryClient.discover_template_attributes).
# They are per-org and change on every install — shipping hardcoded
# values caused silent FK failures on any host that wasn't the one
# they were captured on. DR_TEMPLATE_* env vars are no longer read.

# ============================================================
# dr-load CLI settings
# ============================================================
# Directory containing JBoss app log files
DR_LOG_DIR=/home/auraria/AHS/output

# Seconds between job-status DB polls
DR_POLL_INTERVAL=10

# Output path for the merged report CSV
DR_REPORT_OUTPUT=dr_report.csv

# Postgres connection (peer auth via sudo — password field is unused)
DR_PG_HOST=localhost
DR_PG_DB=auraria_mgmt
DR_PG_USER=auraria
DR_PG_PASSWORD=
