# eDiscovery API Test Configuration
# Copy this file to .env and fill in your values
#
# All variables use a DR_ prefix to avoid collisions with
# Windows system env vars (e.g. Windows sets USERNAME automatically).

# Base URL for the eDiscovery REST API (no trailing slash)
DR_BASE_URL=https://192.168.58.128:8443/ediscovery/rest

# ============================================================
# System Admin (realm-level access)
# Used by the main test suite (pytest -v)
# ============================================================
DR_USERNAME=DRSysAdmin
DR_PASSWORD=your_password_here
DR_ORGANIZATION=super_system_customer

# ============================================================
# Org User (org-level access, e.g. admin@training)
# Used by org_user tests (pytest -m org_user -v)
# Leave blank to skip org-user tests automatically.
# ============================================================
DR_ORG_USERNAME=admin
DR_ORG_PASSWORD=your_org_password_here
DR_ORG_ORGANIZATION=training

# ============================================================
# Optional settings
# ============================================================
# LDAP domain (leave empty if not using LDAP)
DR_LDAP_DOMAIN=
DR_ORG_LDAP_DOMAIN=

# Timeouts (seconds)
DR_REQUEST_TIMEOUT=30
DR_LONG_REQUEST_TIMEOUT=120

# Load test settings
DR_LOAD_TEST_USERS=10
DR_LOAD_TEST_SPAWN_RATE=2
DR_LOAD_TEST_DURATION=60

# SSL verification (set to false for self-signed certs)
DR_VERIFY_SSL=false

# ============================================================
# Indexing Workflow Settings
# Used by test_indexing_workflow.py and locustfile_indexing.py
# ============================================================
# Path on the NFS import connector where the load-test dataset lives,
# and a short label used to name the dataset/corpus per workflow.
DR_NFS_IMPORT_PATH=/testload
DR_NFS_DATASET_NAME=testload

# Per-workflow indexing-completion poll (locustfile_indexing.py).
# After corpusManager/createRepresentation, taskManager/getTasks is polled
# every DR_INDEX_POLL_INTERVAL seconds until tasks[].dateCompleted is set,
# or DR_INDEX_POLL_TIMEOUT seconds elapse.
DR_INDEX_POLL_INTERVAL=5
DR_INDEX_POLL_TIMEOUT=600

# ── Pytest-only handles (locustfile_indexing.py v0.03+ resolves these at runtime) ──
# The load test (locustfile_indexing.py) looks these up dynamically in on_start via:
#   - adminOrgManager/listConnectors   (type=NFS, mode=READ)
#   - orgManager/listRoles             (name="Organization Administrator")
#   - orgManager/listTemplates         (defaultTemplate=true)
# The vars below are still read by tests/test_indexing_workflow.py and may be
# referenced by helpers/preflight.py. Values are org-specific — get them from
# the browser Network tab (createCase request body) or from a one-shot script.
DR_NFS_CONNECTOR_HANDLE=0000840201143a35f1f34d8d9a76a34146268ddc
DR_ADMIN_ROLE_HANDLE=00008798cf6b043a18104ccd8c437b29f688f847

DR_TEMPLATE_ALIAS_LISTS=18621
DR_TEMPLATE_ANALYTICAL_SETTINGS=18542
DR_TEMPLATE_BILLING_REPORT_SETTINGS=18629
DR_TEMPLATE_CUSTOM_FIELDS=18626
DR_TEMPLATE_DOMAIN_LISTS=18565
DR_TEMPLATE_EMAIL_SIGNATURE=18569
DR_TEMPLATE_EXPORT_FIELDS=18537
DR_TEMPLATE_EXPORT_SETTINGS=18558
DR_TEMPLATE_INDEX_SETTINGS=18514
DR_TEMPLATE_LOADFILE_SETTINGS=18623
DR_TEMPLATE_SEARCH_FIELDS=18593
DR_TEMPLATE_DOCUMENT_METADATA=18571
DR_TEMPLATE_USER_EXP=18567
DR_TEMPLATE_REPORT_SETTINGS=18615
DR_TEMPLATE_SEARCH_SETTINGS=18575
DR_TEMPLATE_DUPE_SURVIVORSHIP=18573
DR_TEMPLATE_TAG=18563

# ============================================================
# dr-load CLI settings
# ============================================================
# Directory containing JBoss app log files
DR_LOG_DIR=/home/auraria/AHS/output

# Seconds between job-status DB polls
DR_POLL_INTERVAL=10

# Output path for the merged report CSV
DR_REPORT_OUTPUT=dr_report.csv

# Postgres connection (peer auth via sudo — password field is unused)
DR_PG_HOST=localhost
DR_PG_DB=auraria_mgmt
DR_PG_USER=auraria
DR_PG_PASSWORD=
